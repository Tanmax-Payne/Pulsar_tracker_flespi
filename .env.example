# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FLESPI_TOKEN: Your Flespi.io API token, used server-side only (the
# /api/flespi proxy) — never exposed to the browser.
# Get it from https://flespi.io/tokens
FLESPI_TOKEN=

# NEXT_PUBLIC_FLESPI_TOKEN: Required separately for the browser's MQTT
# WebSocket connection (live updates with zero REST cost). This is
# exposed to the client bundle by design (NEXT_PUBLIC_ prefix) — if
# unset, MQTT never even attempts to connect and the app silently falls
# back to REST-polling-only for every viewer. Can be the same token as
# FLESPI_TOKEN, or a separate one scoped to just MQTT if you want the
# browser-exposed token to carry narrower permissions.
# NEXT_PUBLIC_ vars are baked in at BUILD TIME — after setting/changing
# this in Vercel, you must trigger a new deployment for it to take effect.
NEXT_PUBLIC_FLESPI_TOKEN=

# NEXT_PUBLIC_DEVICE_IDS: Comma-separated Flespi device IDs to track,
# e.g. "1001,1002". Also baked in at build time.
NEXT_PUBLIC_DEVICE_IDS=
